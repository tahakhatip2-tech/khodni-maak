{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=\"-Xmx3072m -XX:MaxMetaspaceSize=512m\""
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=\"-Xmx3072m -XX:MaxMetaspaceSize=512m\""
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
